# IBM watsonx.ai credentials
# Get these from: https://cloud.ibm.com -> watsonx.ai -> your project
IBM_API_KEY=your-ibm-cloud-api-key-here
IBM_PROJECT_ID=your-watsonx-project-id-here
IBM_WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-secret
FLASK_DEBUG=false

# Granite model available in eu-de region
# Run: python list_watsonx_resources.py  to see all available models
GRANITE_MODEL_ID=ibm/granite-4-h-small
